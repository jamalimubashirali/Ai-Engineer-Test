# ============================================================
# AI Engineer Assessment — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- OpenRouter API (used as a unified gateway for all LLM calls) ---
# Get your free key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Model slugs — all free-tier models on OpenRouter ---
# Used for all text / instruction tasks (Task 1.1, 2.1, 2.3, Section 3)
CHAT_MODEL=openai/gpt-oss-20b:free

# Used for vision / image tasks (Task 2.2)
VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# --- Embeddings ---
# Task 2.3 uses HuggingFace sentence-transformers locally (no API key needed).
# Model: all-MiniLM-L6-v2  — downloaded automatically on first run.
